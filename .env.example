# FaultLine Configuration
# Copy this file to .env and adjust values for your deployment.

# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_DSN=postgresql://faultline:faultline@localhost:5432/faultline

# ── Qdrant ───────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=faultline-default

# ── LLM API ─────────────────────────────────────────────────────────
QWEN_API_URL=http://localhost:11434/v1/chat/completions
WGM_LLM_MODEL=qwen/qwen3.5-9b
CATEGORY_LLM_MODEL=qwen2.5-coder

# ── Re-Embedder ─────────────────────────────────────────────────────
REEMBED_INTERVAL=10

# ── FaultLine API (used by OpenWebUI Filter) ────────────────────────
FAULTLINE_API_URL=http://localhost:8001

# ── OpenWebUI (used by Filter when no LLM_URL valve set) ────────────
OPENWEBUI_API_URL=http://host.docker.internal:3000/api

# ── Production Hardening (dprompt-41) ───────────────────────────────
# Timeouts (seconds)
HTTPX_TIMEOUT=10
DB_TIMEOUT=30
QDRANT_TIMEOUT=10

# Connection pooling
DB_POOL_SIZE=10

# Rate limiting
RATE_LIMIT_PER_MIN=100

# Logging
LOG_LEVEL=INFO
