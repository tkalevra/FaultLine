# FaultLine Configuration
# Copy this file to .env and adjust values for your deployment.

# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_USER=faultline
POSTGRES_PASSWORD=faultline
POSTGRES_DB=faultline
POSTGRES_DSN=postgresql://faultline:faultline@localhost:5432/faultline

# ── Qdrant ───────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=faultline-default

# ── Redis (Inlet Dedup Cache) ──────────────────────────────────────
# Used by OpenWebUI Filter for request-level deduplication (dprompt-127).
# Prevents duplicate LLM extraction calls when OpenWebUI retries messages.
# CRITICAL: Must match the hostname of your Redis container.
# - Docker Compose: redis://faultline-redis:6379/0 (service name, not localhost)
# - Local dev: redis://localhost:6379/0
# - Portainer: redis://faultline-redis:6379/0 (if Redis on same network)
REDIS_URL=redis://faultline-redis:6379/0

# ── LLM API ─────────────────────────────────────────────────────────
QWEN_API_URL=http://localhost:11434/v1/chat/completions
WGM_LLM_MODEL=qwen/qwen3.5-9b
CATEGORY_LLM_MODEL=qwen2.5-coder

# ── Re-Embedder ─────────────────────────────────────────────────────
# Interval (seconds) between re-embedder reconciliation cycles.
# Lower = more frequent reconciliation (higher resource use, faster updates)
# Higher = less frequent (less blocking, useful during testing)
# Reconciliation hits all Qdrant collections and can block request processing.
# For testing: use 300+ to prevent interference with active requests.
# For production: use 60 (default) or lower for faster staged fact promotion.
REEMBED_INTERVAL=60

# ── FaultLine API (used by OpenWebUI Filter) ────────────────────────
FAULTLINE_API_URL=http://localhost:8001

# ── OpenWebUI (used by Filter when no LLM_URL valve set) ────────────
OPENWEBUI_API_URL=http://host.docker.internal:3000/api

# ── Production Hardening (dprompt-41) ───────────────────────────────
# Timeouts (seconds)
HTTPX_TIMEOUT=10
DB_TIMEOUT=30
QDRANT_TIMEOUT=10

# Connection pooling
DB_POOL_SIZE=10

# Rate limiting
RATE_LIMIT_PER_MIN=100

# Logging
LOG_LEVEL=INFO

# Debug/Diagnostics
# Enable LM Studio backend stats logging (time_to_first_token, tokens_per_second, etc.)
# Set to "true" or "1" to log on every LLM call. Helps diagnose backend vs FaultLine latency.
DEBUG_LM_STUDIO_STATS=false
