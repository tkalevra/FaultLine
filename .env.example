# ===================================================================================
# FaultLine Configuration - Environment Variables
# ===================================================================================
#
# Copy this file to .env and adjust values for your environment.
# All configuration uses environment variables for flexibility across:
# - Local development (.env file)
# - Docker Compose (environment section)
# - Kubernetes (ConfigMap/Secrets)
# - CI/CD pipelines (secrets)
#
# Each setting has a plain-English description to help non-technical users.
#

# ==================================================================================
# DATABASE CONFIGURATION - REQUIRED
# ==================================================================================

# PostgreSQL connection string.
# Format: postgresql://username:password@hostname:port/database
# This database stores all facts, entities, relationships, and user schemas.
# REQUIRED - Must be set, no default value.
# Examples:
#   Docker Compose (this quick-start; host = the `postgres` service): postgresql://faultline:faultline@postgres:5432/faultline
#   Local development (bare-metal Postgres on the host): postgresql://faultline:faultline@localhost:5432/faultline_test
#   Production: postgresql://user:strong_password@db.example.com:5432/faultline
# NOTE: inside `docker compose`, the API reaches Postgres at host `postgres` (the service name),
# NOT `localhost` — `localhost` resolves to the API's own container and yields "connection refused".
POSTGRES_DSN=postgresql://faultline:faultline@postgres:5432/faultline


# ==================================================================================
# PROVISIONING CONFIGURATION - User Schema Setup
# ==================================================================================

# How often (in seconds) to check for new users to set up.
# Lower values = faster user setup, higher values = less database checking.
# Safe values: 5 (default, most systems), 10 (slower onboarding), 1 (very fast).
# Default: 5 seconds
PROVISIONING_POLL_INTERVAL=5

# How many user schemas to create in each batch.
# Higher = faster overall provisioning, but uses more server resources.
# Lower = slower but uses fewer resources at once.
# Safe values: 10 (default), 5 (conservative), 20 (aggressive).
# Default: 10 users per batch
PROVISIONING_BATCH_SIZE=10

# Prefix for user schema names in PostgreSQL.
# Each user gets a schema named: {PREFIX}_{user_id}
# Example: If PREFIX=faultline, user gets "faultline_550e8400..."
# Must contain only letters, numbers, and underscores.
# Default: faultline (change only if you have naming conflicts)
SCHEMA_NAME_PREFIX=faultline


# ==================================================================================
# VECTOR DATABASE CONFIGURATION - Qdrant (Semantic Search)
# ==================================================================================

# URL of the Qdrant vector database server.
# Used for semantic search and contextual fact retrieval.
# Format: http://hostname:port (usually port 6333)
# Examples:
#   Local development: http://localhost:6333
#   Docker Compose: http://qdrant:6333
#   Remote: http://qdrant.example.com:6333
# Default: http://qdrant:6333 (Docker service name)
QDRANT_URL=http://qdrant:6333

# Name of the Qdrant collection for storing embeddings.
# Can be the same for all users (simple) or per-user (faultline-{user_id}).
# Examples:
#   Single collection (simple): faultline-test
#   Per-user collections: faultline-{user_id} (generated automatically)
# Default: faultline-test (development mode)
QDRANT_COLLECTION=faultline-test

# Enable or disable Class C unstructured memory writes to Qdrant.
# When true (default), text that GLiNER2 cannot extract structured triples from is
# stored directly in Qdrant as a Class C context fact (rel_type="context", confidence=0.4).
# Set to false to disable this fallback path and keep Qdrant free of unstructured noise.
# Values: true, false, 1, 0, no
# Default: true
SHORT_TERM_MEMORY=true


# ==================================================================================
# REDIS CONFIGURATION - Optional Caching & Deduplication
# ==================================================================================

# Optional Redis URL for caching and deduplication.
# If NOT set, caching is disabled (system works fine without it).
# If set, enables caching to reduce duplicate API calls and improve performance.
# Format: redis://hostname:port/database
# Examples:
#   Local development (optional): redis://localhost:6379/0
#   Docker Compose (optional): redis://redis:6379/0
#   Leave empty if you don't have Redis (system still works)
# Default: Not set (caching disabled, system works fine)
# REDIS_URL=redis://localhost:6379/0


# ==================================================================================
# LLM BACKEND CONFIGURATION
# ==================================================================================

# Backend type — tells FaultLine which protocol to use.
# Values: openwebui | ollama | lm_studio | anthropic | openai | groq | localai | raw
#
#   openwebui  — OpenWebUI at /api/chat/completions (default for Docker deployments)
#   ollama     — Ollama direct at /v1/chat/completions
#   lm_studio  — LM Studio at /v1/chat/completions
#   anthropic  — Anthropic Claude API at /v1/messages (different auth + response format)
#   openai     — OpenAI API at /v1/chat/completions
#   groq       — Groq at /openai/v1/chat/completions
#   raw        — Full URL in LLM_BASE_URL, no path appended
#
# Default: openwebui
LLM_BACKEND_TYPE=openwebui

# Base URL for your LLM backend — hostname + port only, no path.
# The correct API path is appended automatically based on LLM_BACKEND_TYPE.
#
# Examples by backend type:
#   openwebui:  http://open-webui:8080
#   ollama:     http://localhost:11434
#   lm_studio:  http://localhost:1234
#   anthropic:  https://api.anthropic.com
#   openai:     https://api.openai.com
#   groq:       https://api.groq.com
#
# When set alongside LLM_BACKEND_TYPE, this takes priority over all legacy vars.
# Leave unset to use legacy QWEN_API_URL / OPENWEBUI_INTERNAL_URL / OPENWEBUI_URL.
# LLM_BASE_URL=http://open-webui:8080

# Optional API key for LLM authentication.
#   - Anthropic: required (sk-ant-...)
#   - OpenAI: required (sk-...)
#   - Groq: required (gsk_...)
#   - Ollama: not required
#   - LM Studio: not required (accepts anything if set)
#   - OpenWebUI: session token if auth enabled
# LLM_API_KEY=

# LLM model name for fact extraction, validation, and ontology inference.
# Must match what your backend serves.
# Examples: qwen2.5:7b | claude-3-5-sonnet-20241022 | gpt-4o | llama-3.1-70b-versatile
# Default: qwen/qwen3.5-9b
WGM_LLM_MODEL=qwen/qwen3.5-9b

# LLM model for category/taxonomy classification (can be the same as WGM_LLM_MODEL).
# Default: qwen2.5-coder
CATEGORY_LLM_MODEL=qwen2.5-coder


# ==================================================================================
# LLM BACKEND — LEGACY VARIABLES (still supported, use above when possible)
# ==================================================================================

# Direct LLM backend URL — full URL including path.
# Highest priority legacy var. Use LLM_BACKEND_TYPE + LLM_BASE_URL for new setups.
# QWEN_API_URL=http://localhost:11434/v1/chat/completions

# OpenWebUI base URL (external, user-configured).
# Appends /api/chat/completions automatically.
# OPENWEBUI_URL=http://open-webui:8080

# OpenWebUI internal URL (Docker container-to-container).
# Use this when FaultLine and OpenWebUI are in the same Docker network.
# Takes priority over OPENWEBUI_URL.
# OPENWEBUI_INTERNAL_URL=http://open-webui:8080


# ==================================================================================
# EMBEDDING CONFIGURATION
# ==================================================================================

# Embedding model name sent to the external embedding API.
# Only needed if your backend serves a different model under a different identifier.
# For Ollama with nomic-embed-text pulled: leave as default.
# Default: text-embedding-nomic-embed-text-v1.5
# EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5

# Explicit embedding endpoint override.
# Set when your embedding endpoint differs from the chat endpoint base.
# When unset, derived automatically from LLM_BASE_URL or chat endpoint.
# Default: derived (e.g. http://open-webui:8080/api/embeddings)
# EMBEDDING_API_URL=

# How long (in seconds) to cache embeddings in Redis.
# Only used if REDIS_URL is set.
# Higher values = fewer API calls to embedding service, but potentially stale data.
# Lower values = fresher data, but more API calls.
# Examples: 3600 (1 hour), 86400 (1 day), 604800 (1 week)
# Default: 86400 (1 day)
EMBEDDING_CACHE_TTL=86400


# ==================================================================================
# RE-EMBEDDER BACKGROUND JOB - Fact Promotion & Learning
# ==================================================================================

# How often (in seconds) the background re-embedder job runs.
# Responsible for:
#   - Promoting staged facts to permanent storage
#   - Embedding updates for Qdrant
#   - Ontology learning from novel facts
#   - Name conflict resolution
# Lower values = faster learning, higher = less frequent processing.
# Safe values: 60 (default), 10 (very responsive), 300 (resource conservative).
# Default: 60 seconds
REEMBED_INTERVAL=60

# Minimum confidence score (0.0-1.0) to sync facts to Qdrant.
# Only facts with confidence >= this threshold are added to vector search.
# Examples:
#   0.0 = All facts (default, most systems)
#   0.5 = Only medium-to-high confidence facts
#   0.8 = Only very confident facts
# Default: 0.0 (sync all facts)
QDRANT_SYNC_CONFIDENCE_THRESHOLD=0.0


# ==================================================================================
# TIMEOUT CONFIGURATION - How Long to Wait Before Giving Up
# ==================================================================================

# How long (in seconds) to wait for HTTP responses from LLM.
# If your LLM is slow or over-loaded, increase this.
# Safe values: 10 (default), 30 (slower LLM), 60 (very slow).
# Default: 10 seconds
HTTPX_TIMEOUT=10

# How long (in seconds) to wait for database responses.
# If your database is slow or under load, increase this.
# Safe values: 30 (default), 60 (slower DB), 120 (very slow).
# Default: 30 seconds
DB_TIMEOUT=30

# How long (in seconds) to wait for Qdrant vector search responses.
# If Qdrant is under load or has many vectors, increase this.
# Safe values: 10 (default), 30 (slower Qdrant).
# Default: 10 seconds
QDRANT_TIMEOUT=10

# Per-operation LLM call timeouts (seconds).
# Increase if your backend is slow; decrease for faster failure detection.
LLM_TIMEOUT_DEFAULT=30
LLM_TIMEOUT_EXTRACTION=30
LLM_TIMEOUT_RETRACTION_EXTRACTION=60
LLM_TIMEOUT_INTENT_CLASSIFICATION=5
LLM_TIMEOUT_VALIDATION=20
LLM_TIMEOUT_ENRICHMENT=15
LLM_TIMEOUT_CORRECTION=25
LLM_TIMEOUT_EMBEDDING=10
LLM_TIMEOUT_TAXONOMY_DISCOVERY=20

# Circuit breaker: open after this many consecutive LLM failures.
LLM_CIRCUIT_BREAKER_THRESHOLD=5

# Circuit breaker: seconds before attempting reset after opening.
LLM_CIRCUIT_BREAKER_TIMEOUT=30


# ==================================================================================
# CONNECTION POOL CONFIGURATION - Concurrent Connections
# ==================================================================================

# Maximum number of simultaneous database connections.
# Higher = more concurrent queries, but uses more server resources.
# Lower = fewer resources, but queries may queue up waiting for connections.
# Safe values: 10 (default, small systems), 20 (medium), 50 (large).
# Default: 10 connections
DB_POOL_SIZE=10


# ==================================================================================
# RATE LIMITING - Prevent Abuse
# ==================================================================================

# Maximum API requests per user per minute.
# Prevents single users from overwhelming the system.
# Examples:
#   100 (default, most systems)
#   200 (high-traffic systems)
#   30 (strict rate limiting)
# Default: 100 requests/minute
RATE_LIMIT_PER_MIN=100


# ==================================================================================
# LOGGING CONFIGURATION - Debug Output
# ==================================================================================

# Logging level for FaultLine (DEBUG, INFO, WARNING, ERROR, CRITICAL).
# DEBUG = very detailed output (development only)
# INFO = normal operation messages (recommended)
# WARNING = only warnings and errors
# ERROR = only errors
# CRITICAL = only critical failures
# Default: INFO
FAULTLINE_LOG_LEVEL=INFO


# ==================================================================================
# API CONFIGURATION
# ==================================================================================

# Public URL of FaultLine API (used by filter to call backend).
# Set to the actual URL where FaultLine is running.
# Format: http://hostname:port or https://hostname
# Examples:
#   Local development: http://localhost:8000
#   Docker Compose: http://faultline:8000
#   Production: https://api.example.com
# Default: http://localhost:8000
FAULTLINE_API_URL=http://localhost:8000


# ==================================================================================
# MCP SERVER CONFIGURATION
# ==================================================================================

# Your user UUID for FaultLine memory.
# Generate one: python3 -c "import uuid; print(uuid.uuid4())"
# The backend auto-provisions your schema on first use — no pre-registration needed.
# Required when running the MCP server (stdio or HTTP transport).
# FAULTLINE_USER_ID=

# Bearer token for the MCP HTTP transport (port 8002).
# Required when faultline-mcp is exposed over the network (Docker sidecar, remote).
# Not needed for stdio transport (Claude Desktop local process).
# Generate: openssl rand -hex 32
# MCP_API_KEY=


# ==================================================================================
# MISCELLANEOUS / OPTIONAL
# ==================================================================================

# Enable debug logging for LM Studio (development only).
# Logs detailed timing and performance statistics.
# Only useful for debugging LM Studio integration.
# Values: true, false, 1, 0, yes, no
# Default: false
DEBUG_LM_STUDIO_STATS=false
