# FaultLine Configuration
# Copy this file to .env and adjust for your deployment

# REQUIRED: Database
POSTGRES_USER=faultline
POSTGRES_PASSWORD=faultline
POSTGRES_DB=faultline
POSTGRES_DSN=postgresql://faultline:faultline@postgres:5432/faultline

# REQUIRED: Vector search
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=faultline

# REQUIRED: Cache layer
REDIS_URL=redis://redis:6379/0

# REQUIRED: OpenWebUI integration
OPENWEBUI_URL=http://open-webui:8080

# OPTIONAL: Performance tuning
REEMBED_INTERVAL=60
DB_POOL_SIZE=15
RATE_LIMIT_PER_MIN=100

# OPTIONAL: Timeouts (seconds)
HTTPX_TIMEOUT=10
DB_TIMEOUT=30
QDRANT_TIMEOUT=10

# OPTIONAL: Logging
LOG_LEVEL=INFO
